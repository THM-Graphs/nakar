{
  "name": "nakar-server",
  "version": "0.0.0",
  "private": true,
  "description": "A Strapi application",
  "scripts": {
    "build": "strapi build",
    "build:docker": "docker buildx build -f Dockerfile -t ghcr.io/thm-graphs/nakar/server:dev .",
    "build:docker:mutliarch": "docker buildx build --platform linux/amd64,linux/arm64 -f Dockerfile -t ghcr.io/thm-graphs/nakar/server:dev .",
    "develop": "strapi develop",
    "start": "strapi start",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier . --check",
    "format:fix": "prettier . --write",
    "audit": "npm audit --audit-level high",
    "test": "jest",
    "export": "strapi export --no-compress --no-encrypt -f export",
    "import": "strapi import -f export.tar",
    "version": "echo $npm_package_version",
    "pre-commit": "npm run lint:fix && npm run format:fix"
  },
  "dependencies": {
    "@strapi/plugin-users-permissions": "5.31.3",
    "@strapi/strapi": "5.31.3",
    "better-sqlite3": "12.4.1",
    "cors": "^2.8.5",
    "express": "^5.0.0",
    "express-fileupload": "^1.5.1",
    "handlebars": "^4.0.0",
    "handlebars-helpers": "^0.10.0",
    "http-errors": "^2.0.0",
    "mysql2": "^3.14.1",
    "neo4j-driver": "^5.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.0.0",
    "rxjs": "^7.0.0",
    "sanitize-filename": "^1.0.0",
    "socket.io": "^4.8.1",
    "styled-components": "^6.0.0",
    "tar": "^7.0.0",
    "ts-pattern": "^5.0.0",
    "undici": "^7.16.0",
    "uuid": "^11.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@tsconfig/node20": "^20.0.0",
    "@types/express": "^5.0.0",
    "@types/express-fileupload": "^1.0.0",
    "@types/handlebars-helpers": "^0.5.6",
    "@types/http-errors": "^2.0.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^9.0.0",
    "openapi-typescript": "^7.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5",
    "typescript-eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=20.0.0 <=24.x.x",
    "npm": ">=6.0.0"
  },
  "strapi": {
    "uuid": "4257914e-0ce5-42cf-91c6-ffa7a5ecd95a",
    "telemetryDisabled": true
  }
}
