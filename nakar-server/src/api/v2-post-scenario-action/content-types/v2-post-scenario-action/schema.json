{
  "kind": "collectionType",
  "collectionName": "v2_post_scenario_actions",
  "info": {
    "singularName": "v2-post-scenario-action",
    "pluralName": "v2-post-scenario-actions",
    "displayName": "V2 Post Scenario Action"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "type": {
      "type": "enumeration",
      "enum": [
        "connectResultNodes",
        "compressRelationships",
        "compressNodes",
        "layout"
      ]
    },
    "scenario": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::v2-scenario.v2-scenario",
      "inversedBy": "postActions"
    },
    "label": {
      "type": "string"
    },
    "circleRadius": {
      "type": "decimal"
    },
    "layoutAlgorithm": {
      "type": "enumeration",
      "enum": [
        "forceDirected",
        "circle"
      ]
    }
  }
}
