{
  "kind": "collectionType",
  "collectionName": "canvas_label_settings",
  "info": {
    "singularName": "canvas-label-setting",
    "pluralName": "canvas-label-settings",
    "displayName": "Canvas Node Setting"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "label": {
      "type": "string",
      "unique": false
    },
    "radius": {
      "type": "decimal"
    },
    "customRadius": {
      "type": "boolean",
      "default": false
    },
    "colorIndex": {
      "type": "enumeration",
      "enum": [
        "color0",
        "color1",
        "color2",
        "color3",
        "color4",
        "color5"
      ]
    },
    "customColorIndex": {
      "type": "boolean",
      "default": false
    },
    "canvas": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::canvas.canvas",
      "inversedBy": "nodeSettings"
    }
  }
}
