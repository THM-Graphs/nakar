{
  "kind": "collectionType",
  "collectionName": "database_connections",
  "info": {
    "singularName": "database-connection",
    "pluralName": "database-connections",
    "displayName": "Database Connection",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "project": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::project.project",
      "inversedBy": "databaseConnections"
    },
    "databaseType": {
      "type": "enumeration",
      "enum": ["neo4j"],
      "default": "neo4j",
      "required": true
    },
    "username": {
      "type": "string"
    },
    "password": {
      "type": "string"
    },
    "database": {
      "type": "string"
    },
    "connectionUrl": {
      "type": "string"
    },
    "browserUrl": {
      "type": "string"
    },
    "commonPropertiesLeft": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::common-property.common-property",
      "mappedBy": "leftDatabase"
    },
    "commonPropertiesRight": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::common-property.common-property",
      "mappedBy": "rightDatabase"
    },
    "queries": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::query.query",
      "mappedBy": "database"
    },
    "nodeConfigurations": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::node-configuration.node-configuration",
      "mappedBy": "database"
    }
  }
}
