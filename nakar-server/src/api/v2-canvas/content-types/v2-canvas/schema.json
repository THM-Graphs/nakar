{
  "kind": "collectionType",
  "collectionName": "v2_canvases",
  "info": {
    "singularName": "v2-canvas",
    "pluralName": "v2-canvases",
    "displayName": "V2 Canvas",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "room": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::v2-room.v2-room",
      "inversedBy": "canvases"
    },
    "graph": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "files"
      ]
    },
    "growNodesBasedOnDegree": {
      "type": "boolean"
    },
    "scaleType": {
      "type": "enumeration",
      "enum": [
        "linear",
        "log2",
        "logn",
        "log10"
      ]
    },
    "growNodesBasedOnDegreeFactor": {
      "type": "decimal"
    },
    "compressRelationshipsWidthFactor": {
      "type": "decimal"
    },
    "treatNameInQueryAsLabel": {
      "type": "boolean"
    },
    "nodeSettings": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::v2-canvas-label-setting.v2-canvas-label-setting",
      "mappedBy": "canvas"
    }
  }
}
