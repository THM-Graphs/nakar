{
  "kind": "collectionType",
  "collectionName": "v2_projects",
  "info": {
    "singularName": "v2-project",
    "pluralName": "v2-projects",
    "displayName": "V2 Project",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "owner": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "projects"
    },
    "collaborators": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "plugin::users-permissions.user",
      "inversedBy": "projectCollaborations"
    },
    "databaseConnections": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::v2-database-connection.v2-database-connection",
      "mappedBy": "project"
    },
    "rooms": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::v2-room.v2-room",
      "mappedBy": "project"
    },
    "notes": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::v2-note.v2-note",
      "mappedBy": "project"
    },
    "scenarioGroups": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::v2-scenario-group.v2-scenario-group",
      "mappedBy": "project"
    },
    "commonProperties": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::v2-common-property.v2-common-property",
      "mappedBy": "project"
    }
  }
}
