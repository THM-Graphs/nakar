{
  "name": "nakar-client-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:docker": "docker build -f Dockerfile -t ghcr.io/thm-graphs/nakar/client-web:dev .",
    "build:docker:mutliarch": "docker buildx build --platform linux/amd64,linux/arm64 -f Dockerfile -t ghcr.io/thm-graphs/nakar/client-web:dev .",
    "start:docker": "docker run -it --rm -p 5173:80 ghcr.io/thm-graphs/nakar/client-web:dev",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier . --check",
    "format:fix": "prettier . --write",
    "audit": "npm audit",
    "version": "echo $npm_package_version",
    "pre-commit": "tsc -b && npm run lint:fix && npm run format:fix"
  },
  "dependencies": {
    "@hey-api/client-fetch": "^0.5.7",
    "@neo4j-cypher/react-codemirror": "^2.0.0-next.31",
    "@uiw/react-md-editor": "^4.0.11",
    "api-client": "file:./packages/api-client",
    "bootstrap": "^5.3.3",
    "bootstrap-icons": "^1.11.3",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "dotenv": "^17.4.2",
    "file-saver": "^2.0.5",
    "immer": "^11.1.8",
    "interactjs": "^1.10.27",
    "react": "^19.2.6",
    "react-bootstrap": "^2.10.7",
    "react-dom": "^19.2.6",
    "react-router": "^7.15.1",
    "rxjs": "^7.8.1",
    "socket.io-client": "^4.8.1",
    "tinykeys": "^4.0.0",
    "ts-pattern": "^5.6.0",
    "uuid": "^11.0.5",
    "zod": "^4.4.3",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/d3": "^7.4.3",
    "@types/file-saver": "^2.0.7",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.4.2",
    "typescript": "5.4.5",
    "typescript-eslint": "^8.18.2",
    "vite": "^8.0.14"
  }
}
