{
  "name": "nakar-client-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:docker": "docker buildx build -f Dockerfile -t ghcr.io/thm-graphs/nakar/client-web:dev .",
    "build:docker:mutliarch": "docker buildx build --platform linux/amd64,linux/arm64 -f Dockerfile -t ghcr.io/thm-graphs/nakar/client-web:dev .",
    "build:api": "npx openapi-ts --input http://127.0.0.1:1338/api.yaml --output src-gen --client @hey-api/client-fetch",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier . --check",
    "format:fix": "prettier . --write",
    "audit": "npm audit",
    "version": "echo $npm_package_version",
    "pre-commit": "npm run lint:fix && npm run format:fix"
  },
  "dependencies": {
    "@hey-api/client-fetch": "^0.5.7",
    "@neo4j-cypher/react-codemirror": "^2.0.0-next.31",
    "@neo4j-nvl/react": "^0.3.6",
    "@uiw/react-md-editor": "^4.0.11",
    "bootstrap": "^5.3.3",
    "bootstrap-icons": "^1.11.3",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "dotenv": "^16.4.7",
    "file-saver": "^2.0.5",
    "immer": "^10.1.1",
    "interactjs": "^1.10.27",
    "react": "^18.3.1",
    "react-bootstrap": "^2.10.7",
    "react-dom": "^18.3.1",
    "react-router": "7.12.0",
    "rxjs": "^7.8.1",
    "socket.io-client": "^4.8.1",
    "ts-pattern": "^5.6.0",
    "uuid": "^11.0.5",
    "zod": "^3.24.1",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@hey-api/openapi-ts": "^0.60.1",
    "@types/d3": "^7.4.3",
    "@types/file-saver": "^2.0.7",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.35.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.18.2",
    "vite": "7.1.11"
  }
}
