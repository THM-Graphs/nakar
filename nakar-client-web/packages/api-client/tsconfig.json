{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "rootDir": "src-gen",
    "sourceMap": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "isolatedModules": true
  },
  "include": ["src-gen/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
